<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="theme-color" content="#1a2e1a">
<title>Short-Link Unmasking Race · CYBER-SCOUT</title>
<style>
  /* ── RESET & BASE ── */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { font-size: 16px; -webkit-tap-highlight-color: transparent; }

  :root {
    --green-deep:    #1a2e1a;
    --green-forest:  #2d4a2d;
    --green-scout:   #3d6b3d;
    --green-bright:  #4caf50;
    --green-light:   #81c784;
    --khaki:         #c4a882;
    --khaki-pale:    #ede0cc;
    --cyber:         #00bcd4;
    --cyber-dim:     #006d7a;
    --amber:         #ffc107;
    --danger:        #e53935;
    --danger-dim:    #7b1515;
    --safe:          #2e7d32;
    --safe-bright:   #43a047;
    --white:         #f4f8f4;
    --muted:         #7da87d;
    --card-bg:       rgba(30,55,30,.85);
    --border:        rgba(77,160,77,.25);
    --radius:        12px;
    --shadow:        0 4px 24px rgba(0,0,0,.45);
  }

  body {
    background: var(--green-deep);
    color: var(--white);
    font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
    min-height: 100vh;
    overflow-x: hidden;
    background-image:
      radial-gradient(ellipse 80% 50% at 50% 0%, rgba(0,188,212,.07) 0%, transparent 70%),
      repeating-linear-gradient(0deg, transparent, transparent 39px, rgba(77,160,77,.04) 39px, rgba(77,160,77,.04) 40px),
      repeating-linear-gradient(90deg, transparent, transparent 39px, rgba(77,160,77,.04) 39px, rgba(77,160,77,.04) 40px);
  }

  /* ── SCREENS ── */
  .screen {
    display: none;
    min-height: 100vh;
    padding: 24px 16px 40px;
    flex-direction: column;
    align-items: center;
  }
  .screen.active { display: flex; }

  /* ── WELCOME SCREEN ── */
  #screen-welcome {
    justify-content: center;
    text-align: center;
    gap: 0;
  }

  .logo-badge {
    width: 88px;
    height: 88px;
    margin: 0 auto 20px;
    position: relative;
  }
  .logo-badge svg { width: 100%; height: 100%; filter: drop-shadow(0 0 12px rgba(0,188,212,.4)); }

  .welcome-tag {
    font-size: 11px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--cyber);
    margin-bottom: 14px;
    font-weight: 600;
  }

  .welcome-title {
    font-size: clamp(26px, 7vw, 38px);
    font-weight: 800;
    line-height: 1.1;
    color: var(--khaki-pale);
    margin-bottom: 6px;
  }
  .welcome-title .accent { color: var(--cyber); }

  .welcome-sub {
    font-size: 13px;
    color: var(--muted);
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-bottom: 28px;
  }

  .welcome-card {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 24px 20px;
    max-width: 420px;
    width: 100%;
    margin-bottom: 28px;
    text-align: left;
  }

  .welcome-card p {
    font-size: 15px;
    line-height: 1.7;
    color: var(--khaki-pale);
    margin-bottom: 16px;
  }

  .rules-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .rules-list li {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 14px;
    color: var(--muted);
    line-height: 1.5;
  }
  .rules-list li .rule-icon {
    flex-shrink: 0;
    width: 22px;
    height: 22px;
    background: rgba(0,188,212,.15);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    color: var(--cyber);
    margin-top: 1px;
  }

  /* ── BUTTONS ── */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 16px 36px;
    border: none;
    border-radius: var(--radius);
    font-size: 16px;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    cursor: pointer;
    transition: transform .15s, box-shadow .15s, background .15s;
    -webkit-user-select: none;
    user-select: none;
    width: 100%;
    max-width: 320px;
  }
  .btn:active { transform: scale(.97); }

  .btn-primary {
    background: linear-gradient(135deg, var(--green-scout), var(--green-bright));
    color: #fff;
    box-shadow: 0 4px 20px rgba(76,175,80,.35);
  }
  .btn-primary:hover { box-shadow: 0 6px 28px rgba(76,175,80,.5); transform: translateY(-1px); }

  .btn-cyber {
    background: linear-gradient(135deg, var(--cyber-dim), var(--cyber));
    color: var(--green-deep);
    box-shadow: 0 4px 20px rgba(0,188,212,.3);
  }
  .btn-cyber:hover { box-shadow: 0 6px 28px rgba(0,188,212,.5); transform: translateY(-1px); }

  .btn-outline {
    background: transparent;
    border: 2px solid var(--border);
    color: var(--muted);
    font-size: 14px;
    padding: 12px 24px;
  }
  .btn-outline:hover { border-color: var(--green-light); color: var(--green-light); }

  .btn-danger {
    background: linear-gradient(135deg, var(--danger-dim), var(--danger));
    color: #fff;
  }

  /* ── CHALLENGE SCREEN ── */
  #screen-challenge {
    justify-content: flex-start;
    gap: 0;
    padding-top: 16px;
  }

  .challenge-header {
    width: 100%;
    max-width: 480px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 18px;
  }

  .progress-pill {
    font-size: 12px;
    font-weight: 700;
    color: var(--cyber);
    background: rgba(0,188,212,.1);
    border: 1px solid rgba(0,188,212,.25);
    border-radius: 20px;
    padding: 5px 14px;
    letter-spacing: 1px;
  }

  .score-pill {
    font-size: 12px;
    font-weight: 700;
    color: var(--amber);
    background: rgba(255,193,7,.1);
    border: 1px solid rgba(255,193,7,.25);
    border-radius: 20px;
    padding: 5px 14px;
    letter-spacing: 1px;
  }

  /* Progress bar */
  .progress-bar-wrap {
    width: 100%;
    max-width: 480px;
    height: 4px;
    background: rgba(255,255,255,.08);
    border-radius: 2px;
    margin-bottom: 20px;
    overflow: hidden;
  }
  .progress-bar-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--cyber), var(--green-bright));
    border-radius: 2px;
    transition: width .5s ease;
  }

  /* Challenge card */
  .challenge-card {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 24px 20px;
    max-width: 480px;
    width: 100%;
    margin-bottom: 20px;
    box-shadow: var(--shadow);
  }

  .challenge-num {
    font-size: 11px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--cyber);
    margin-bottom: 14px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .challenge-num::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--border);
  }

  .challenge-question {
    font-size: 15px;
    color: var(--muted);
    margin-bottom: 16px;
    line-height: 1.5;
  }

  /* Link display */
  .link-box {
    background: rgba(0,0,0,.35);
    border: 1px solid rgba(0,188,212,.2);
    border-radius: 8px;
    padding: 14px 16px;
    margin-bottom: 10px;
    position: relative;
    overflow: hidden;
  }
  .link-box::before {
    content: '';
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 3px;
    background: var(--cyber);
  }
  .link-label {
    font-size: 10px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--cyber);
    margin-bottom: 6px;
    font-weight: 700;
  }
  .link-value {
    font-family: 'Courier New', 'Lucida Console', monospace;
    font-size: 14px;
    color: var(--amber);
    word-break: break-all;
    line-height: 1.5;
  }

  .destination-box {
    background: rgba(0,0,0,.25);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 14px 16px;
    margin-bottom: 20px;
    position: relative;
    overflow: hidden;
  }
  .destination-box::before {
    content: '';
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 3px;
    background: var(--green-scout);
  }
  .dest-label {
    font-size: 10px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--green-light);
    margin-bottom: 6px;
    font-weight: 700;
  }
  .dest-value {
    font-family: 'Courier New', 'Lucida Console', monospace;
    font-size: 13px;
    color: var(--khaki-pale);
    word-break: break-all;
    line-height: 1.5;
  }

  /* Clue text */
  .clue-text {
    font-size: 14px;
    color: var(--khaki);
    line-height: 1.6;
    margin-bottom: 20px;
    padding: 12px 14px;
    background: rgba(196,168,130,.07);
    border-radius: 8px;
    border-left: 3px solid var(--khaki);
  }
  .clue-text strong { color: var(--khaki-pale); }

  /* Answer buttons */
  .answer-group {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    width: 100%;
    max-width: 480px;
    margin-bottom: 16px;
  }

  .answer-btn {
    padding: 18px 12px;
    border: 2px solid transparent;
    border-radius: var(--radius);
    font-size: 15px;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    cursor: pointer;
    transition: all .2s;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    -webkit-user-select: none;
    user-select: none;
  }
  .answer-btn:active { transform: scale(.95); }

  .answer-btn.safe-btn {
    background: rgba(46,125,50,.2);
    border-color: rgba(67,160,71,.4);
    color: var(--green-light);
  }
  .answer-btn.safe-btn:hover {
    background: rgba(46,125,50,.4);
    border-color: var(--safe-bright);
    box-shadow: 0 0 20px rgba(46,125,50,.3);
  }

  .answer-btn.poisoned-btn {
    background: rgba(229,57,53,.15);
    border-color: rgba(229,57,53,.3);
    color: #ef9a9a;
  }
  .answer-btn.poisoned-btn:hover {
    background: rgba(229,57,53,.3);
    border-color: var(--danger);
    box-shadow: 0 0 20px rgba(229,57,53,.3);
  }

  .answer-btn .btn-icon { font-size: 26px; }
  .answer-btn .btn-label { font-size: 13px; letter-spacing: 1.5px; }

  /* Answer feedback */
  .answer-btn.correct {
    background: rgba(46,125,50,.5) !important;
    border-color: var(--green-bright) !important;
    box-shadow: 0 0 24px rgba(76,175,80,.5) !important;
    animation: correctPulse .4s ease;
  }
  .answer-btn.wrong {
    background: rgba(229,57,53,.4) !important;
    border-color: var(--danger) !important;
    box-shadow: 0 0 24px rgba(229,57,53,.5) !important;
    animation: wrongShake .4s ease;
  }

  @keyframes correctPulse {
    0% { transform: scale(1); }
    50% { transform: scale(1.05); }
    100% { transform: scale(1); }
  }
  @keyframes wrongShake {
    0%, 100% { transform: translateX(0); }
    20% { transform: translateX(-6px); }
    60% { transform: translateX(6px); }
  }

  /* Feedback panel */
  .feedback-panel {
    display: none;
    width: 100%;
    max-width: 480px;
    border-radius: var(--radius);
    padding: 18px 20px;
    margin-bottom: 16px;
    animation: fadeSlide .3s ease;
  }
  .feedback-panel.show { display: block; }
  .feedback-panel.correct-fb {
    background: rgba(46,125,50,.25);
    border: 1px solid rgba(76,175,80,.5);
  }
  .feedback-panel.wrong-fb {
    background: rgba(229,57,53,.2);
    border: 1px solid rgba(229,57,53,.4);
  }

  @keyframes fadeSlide {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .feedback-header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 10px;
  }
  .feedback-icon { font-size: 22px; }
  .feedback-title {
    font-size: 16px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 1px;
  }
  .correct-fb .feedback-title { color: var(--green-bright); }
  .wrong-fb .feedback-title   { color: var(--danger); }

  .feedback-explain {
    font-size: 14px;
    line-height: 1.6;
    color: var(--khaki-pale);
  }
  .feedback-explain strong { color: var(--khaki-pale); font-weight: 700; }
  .feedback-explain .tag {
    display: inline-block;
    padding: 2px 8px;
    border-radius: 4px;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    margin-right: 4px;
  }
  .tag-safe     { background: rgba(46,125,50,.4); color: #a5d6a7; }
  .tag-poisoned { background: rgba(229,57,53,.35); color: #ef9a9a; }

  .btn-next {
    width: 100%;
    max-width: 480px;
    padding: 16px;
    border: none;
    border-radius: var(--radius);
    font-size: 15px;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    cursor: pointer;
    transition: all .2s;
    display: none;
    margin-bottom: 12px;
  }
  .btn-next.show {
    display: block;
    animation: fadeSlide .3s ease;
  }
  .btn-next.next-style {
    background: linear-gradient(135deg, var(--green-forest), var(--green-scout));
    color: #fff;
    box-shadow: 0 4px 16px rgba(61,107,61,.4);
  }
  .btn-next.finish-style {
    background: linear-gradient(135deg, var(--cyber-dim), var(--cyber));
    color: var(--green-deep);
    box-shadow: 0 4px 16px rgba(0,188,212,.3);
  }

  /* ── RESULTS SCREEN ── */
  #screen-results {
    justify-content: center;
    text-align: center;
    gap: 0;
  }

  .results-badge-wrap {
    margin: 0 auto 24px;
    width: 100px;
    height: 100px;
  }
  .results-badge-wrap svg { width: 100%; height: 100%; }

  .results-title {
    font-size: clamp(22px, 6vw, 32px);
    font-weight: 800;
    color: var(--khaki-pale);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 6px;
  }

  .results-rank {
    font-size: 13px;
    letter-spacing: 3px;
    text-transform: uppercase;
    margin-bottom: 28px;
    font-weight: 700;
  }

  .score-card {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 28px 24px;
    max-width: 420px;
    width: 100%;
    margin-bottom: 24px;
    box-shadow: var(--shadow);
  }

  .score-big {
    font-size: 64px;
    font-weight: 900;
    line-height: 1;
    margin-bottom: 4px;
  }

  .score-label {
    font-size: 13px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 24px;
  }

  .score-breakdown {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin-bottom: 20px;
  }

  .breakdown-item {
    background: rgba(0,0,0,.2);
    border-radius: 8px;
    padding: 14px 12px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }
  .breakdown-num {
    font-size: 28px;
    font-weight: 800;
    line-height: 1;
  }
  .breakdown-num.green { color: var(--green-bright); }
  .breakdown-num.red   { color: var(--danger); }
  .breakdown-label {
    font-size: 11px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--muted);
  }

  .rank-message {
    font-size: 14px;
    color: var(--khaki);
    line-height: 1.6;
    padding: 14px;
    background: rgba(196,168,130,.07);
    border-radius: 8px;
    border-left: 3px solid var(--khaki);
    text-align: left;
  }

  /* Review list */
  .review-section {
    width: 100%;
    max-width: 480px;
    margin-bottom: 24px;
    text-align: left;
  }
  .review-heading {
    font-size: 12px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--cyber);
    margin-bottom: 12px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .review-heading::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--border);
  }

  .review-item {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 14px 16px;
    margin-bottom: 10px;
    display: flex;
    align-items: flex-start;
    gap: 12px;
  }
  .review-item.correct-item { border-left: 3px solid var(--green-bright); }
  .review-item.wrong-item   { border-left: 3px solid var(--danger); }
  .review-result-icon { font-size: 18px; flex-shrink: 0; margin-top: 1px; }
  .review-content { flex: 1; min-width: 0; }
  .review-link {
    font-family: 'Courier New', monospace;
    font-size: 12px;
    color: var(--amber);
    word-break: break-all;
    margin-bottom: 4px;
  }
  .review-status-line {
    font-size: 12px;
    color: var(--muted);
  }
  .review-status-line .answer-given { font-weight: 700; }
  .answer-given.correct-answer { color: var(--green-bright); }
  .answer-given.wrong-answer   { color: var(--danger); }

  .results-btns {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    width: 100%;
    max-width: 320px;
  }

  /* ── TOAST ── */
  #toast {
    position: fixed;
    bottom: 24px;
    left: 50%;
    transform: translateX(-50%) translateY(80px);
    background: rgba(30,55,30,.97);
    border: 1px solid var(--border);
    border-radius: 24px;
    padding: 12px 22px;
    font-size: 14px;
    font-weight: 600;
    color: var(--white);
    z-index: 999;
    transition: transform .3s ease;
    white-space: nowrap;
    box-shadow: var(--shadow);
    pointer-events: none;
  }
  #toast.show { transform: translateX(-50%) translateY(0); }

  /* ── MISC ── */
  .spacer { flex: 1; }

  .cyber-line {
    width: 60px;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--cyber), transparent);
    margin: 16px auto;
  }

  /* Animated dots loader */
  .dots::after {
    content: '...';
    animation: dots 1.2s steps(4, end) infinite;
  }
  @keyframes dots {
    0%, 100% { content: ''; }
    25%       { content: '.'; }
    50%       { content: '..'; }
    75%       { content: '...'; }
  }

  /* ── MOBILE FINE-TUNE ── */
  @media (max-width: 380px) {
    .answer-group { grid-template-columns: 1fr 1fr; gap: 8px; }
    .answer-btn   { padding: 14px 8px; }
    .answer-btn .btn-icon { font-size: 22px; }
  }
</style>
</head>
<body>

<!-- ────────────────────────────────────────────
     SCREEN 1: WELCOME
──────────────────────────────────────────── -->
<main id="screen-welcome" class="screen active">

  <div class="logo-badge">
    <svg viewBox="0 0 88 88" fill="none" xmlns="http://www.w3.org/2000/svg">
      <polygon points="44,4 54,26 78,28 61,44 66,68 44,56 22,68 27,44 10,28 34,26"
               stroke="#4caf50" stroke-width="2" fill="rgba(76,175,80,.1)"/>
      <polygon points="44,14 51,28 66,30 55,41 58,56 44,49 30,56 33,41 22,30 37,28"
               stroke="#00bcd4" stroke-width="1" fill="none" opacity=".6"/>
      <text x="44" y="50" text-anchor="middle" dominant-baseline="middle"
            font-family="'Segoe UI',system-ui,sans-serif" font-size="16"
            font-weight="900" fill="#00bcd4">CS</text>
    </svg>
  </div>

  <p class="welcome-tag">// Project CYBER-SCOUT //</p>
  <h1 class="welcome-title">Short-Link<br><span class="accent">Unmasking</span> Race</h1>
  <p class="welcome-sub">Digital Wilderness Challenge</p>

  <div class="cyber-line"></div>

  <div class="welcome-card">
    <p>Find the real destination behind masked links — <strong>without clicking them.</strong></p>
    <ul class="rules-list">
      <li>
        <span class="rule-icon">🔗</span>
        <span>You'll see a <strong>shortened URL</strong> and its real destination.</span>
      </li>
      <li>
        <span class="rule-icon">🕵️</span>
        <span>Study the clues carefully and judge: is the link <strong>SAFE</strong> or <strong>POISONED</strong>?</span>
      </li>
      <li>
        <span class="rule-icon">⚡</span>
        <span><strong>5 challenges</strong> total. Each correct answer earns you <strong>20 points</strong>.</span>
      </li>
      <li>
        <span class="rule-icon">🏅</span>
        <span>Score 80+ to earn your <strong>Cyber-Scout Badge</strong>!</span>
      </li>
    </ul>
  </div>

  <button class="btn btn-primary" onclick="startChallenge()">
    ▶&nbsp; Start Challenge
  </button>

</main>


<!-- ────────────────────────────────────────────
     SCREEN 2: CHALLENGE
──────────────────────────────────────────── -->
<main id="screen-challenge" class="screen">

  <div class="challenge-header">
    <div class="progress-pill" id="progress-text">Challenge 1 of 5</div>
    <div class="score-pill" id="score-text">Score: 0</div>
  </div>

  <div class="progress-bar-wrap">
    <div class="progress-bar-fill" id="progress-bar" style="width:0%"></div>
  </div>

  <div class="challenge-card">
    <div class="challenge-num" id="challenge-num">// Mission 01 //</div>
    <p class="challenge-question" id="challenge-question">Analyze the link below. Where does it really lead?</p>

    <div class="link-box">
      <div class="link-label">🔗 Shortened Link</div>
      <div class="link-value" id="short-link">—</div>
    </div>

    <div class="destination-box">
      <div class="dest-label">📍 Real Destination Revealed</div>
      <div class="dest-value" id="real-dest">—</div>
    </div>

    <div class="clue-text" id="clue-text">—</div>
  </div>

  <div class="answer-group">
    <button class="answer-btn safe-btn" id="btn-safe" onclick="submitAnswer('SAFE')">
      <span class="btn-icon">✅</span>
      <span class="btn-label">Safe</span>
    </button>
    <button class="answer-btn poisoned-btn" id="btn-poisoned" onclick="submitAnswer('POISONED')">
      <span class="btn-icon">☠️</span>
      <span class="btn-label">Poisoned</span>
    </button>
  </div>

  <div class="feedback-panel" id="feedback-panel">
    <div class="feedback-header">
      <span class="feedback-icon" id="feedback-icon">—</span>
      <span class="feedback-title" id="feedback-title">—</span>
    </div>
    <div class="feedback-explain" id="feedback-explain">—</div>
  </div>

  <button class="btn-next" id="btn-next" onclick="nextChallenge()">
    Next Challenge →
  </button>

</main>


<!-- ────────────────────────────────────────────
     SCREEN 3: RESULTS
──────────────────────────────────────────── -->
<main id="screen-results" class="screen">

  <div class="results-badge-wrap">
    <svg id="results-badge-svg" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
      <!-- Drawn dynamically -->
    </svg>
  </div>

  <h2 class="results-title" id="results-title">Mission Complete!</h2>
  <p class="results-rank" id="results-rank" style="color:#ffc107">—</p>

  <div class="score-card">
    <div class="score-big" id="final-score" style="color:#4caf50">0</div>
    <div class="score-label">/ 100 Points</div>
    <div class="score-breakdown">
      <div class="breakdown-item">
        <span class="breakdown-num green" id="correct-count">0</span>
        <span class="breakdown-label">Correct</span>
      </div>
      <div class="breakdown-item">
        <span class="breakdown-num red" id="wrong-count">0</span>
        <span class="breakdown-label">Wrong</span>
      </div>
    </div>
    <div class="rank-message" id="rank-message">—</div>
  </div>

  <div class="review-section">
    <div class="review-heading">After-Action Review</div>
    <div id="review-list"><!-- filled by JS --></div>
  </div>

  <div class="results-btns">
    <button class="btn btn-primary" onclick="restartGame()">↺&nbsp; Play Again</button>
    <button class="btn btn-outline" onclick="showScreen('screen-welcome')">⌂&nbsp; Main Menu</button>
  </div>

</main>

<!-- Toast -->
<div id="toast"></div>

<script>
/* ══════════════════════════════════════════════
   DATA — 5 Short-Link Challenges
══════════════════════════════════════════════ */
const CHALLENGES = [
  {
    id: 1,
    short:   "bit.ly/freeGCash500",
    real:    "http://gcash-promos-win.xyz/claim?ref=phishing2024",
    status:  "POISONED",
    clue:    "The real domain is <strong>gcash-promos-win.xyz</strong> — not the official gcash.com. The '.xyz' top-level domain and hyphenated name are classic phishing signals. GCash never gives away free credits through random shortened links.",
    question:"This link claims to give away free GCash credits. Where does it actually go?"
  },
  {
    id: 2,
    short:   "tinyurl.com/deped-memo-2024",
    real:    "https://www.deped.gov.ph/2024/01/15/official-school-calendar-sy2024-2025/",
    status:  "SAFE",
    clue:    "The destination is the <strong>official DepEd website</strong> (deped.gov.ph). The <em>.gov.ph</em> domain is reserved exclusively for Philippine government agencies, and the URL path matches a real memo format. This link is legitimate.",
    question:"A classmate shared this link to a DepEd memo. Is the destination trustworthy?"
  },
  {
    id: 3,
    short:   "rb.gy/login-fb-verify",
    real:    "http://faceb00k-account-verify.com/login.php",
    status:  "POISONED",
    clue:    "Look closely: the real domain is <strong>faceb00k</strong> (with zeros replacing the letter 'O'). This is a <em>homograph attack</em> — substituting look-alike characters to trick you. The real Facebook domain is always <strong>facebook.com</strong>, never on a random .com with typos.",
    question:"You received a message: 'Verify your Facebook account now!' — where does the link lead?"
  },
  {
    id: 4,
    short:   "cutt.ly/scout-handbook-ph",
    real:    "https://www.bsp.org.ph/resources/handbooks/scout-handbook-2023.pdf",
    status:  "SAFE",
    clue:    "The destination is <strong>bsp.org.ph</strong> — the official domain of the <em>Boy Scouts of the Philippines</em>. The <em>.org.ph</em> extension is a legitimate registered Philippine organization domain. The path also shows a clearly named PDF file.",
    question:"A troop leader shared this as the official Scout Handbook download. Is it safe?"
  },
  {
    id: 5,
    short:   "ow.ly/ScholarshipApply",
    real:    "http://dost-scholarship-apply.000webhostapp.com/form",
    status:  "POISONED",
    clue:    "The real site is hosted on <strong>000webhostapp.com</strong> — a free web hosting service. The official DOST scholarship portal uses <strong>dost.gov.ph</strong>. Government scholarship forms are never hosted on free platforms. Submitting data here risks identity theft.",
    question:"This link promises a DOST scholarship application form. Where does it really go?"
  }
];

/* ══════════════════════════════════════════════
   GAME STATE
══════════════════════════════════════════════ */
let currentIdx   = 0;
let score        = 0;
let answered     = false;
let userAnswers  = [];   // {challengeId, given, correct, isCorrect}

/* ══════════════════════════════════════════════
   SCREEN MANAGEMENT
══════════════════════════════════════════════ */
function showScreen(id) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  window.scrollTo(0, 0);
}

/* ══════════════════════════════════════════════
   START GAME
══════════════════════════════════════════════ */
function startChallenge() {
  currentIdx  = 0;
  score       = 0;
  answered    = false;
  userAnswers = [];
  showScreen('screen-challenge');
  loadChallenge(0);
}

/* ══════════════════════════════════════════════
   LOAD CHALLENGE
══════════════════════════════════════════════ */
function loadChallenge(idx) {
  answered = false;
  const c = CHALLENGES[idx];

  // Header
  document.getElementById('progress-text').textContent = `Challenge ${idx + 1} of ${CHALLENGES.length}`;
  document.getElementById('score-text').textContent    = `Score: ${score}`;
  document.getElementById('progress-bar').style.width  = `${(idx / CHALLENGES.length) * 100}%`;

  // Card content
  document.getElementById('challenge-num').textContent  = `// Mission 0${c.id} //`;
  document.getElementById('challenge-question').textContent = c.question;
  document.getElementById('short-link').textContent     = c.short;
  document.getElementById('real-dest').textContent      = c.real;
  document.getElementById('clue-text').innerHTML        = '🔎 <strong>Clue:</strong> ' + c.clue;

  // Reset UI
  const btnSafe     = document.getElementById('btn-safe');
  const btnPoisoned = document.getElementById('btn-poisoned');
  btnSafe.className     = 'answer-btn safe-btn';
  btnPoisoned.className = 'answer-btn poisoned-btn';
  btnSafe.disabled     = false;
  btnPoisoned.disabled = false;

  const fb   = document.getElementById('feedback-panel');
  fb.className = 'feedback-panel';

  const btnNext = document.getElementById('btn-next');
  btnNext.className = 'btn-next';
  btnNext.textContent = idx < CHALLENGES.length - 1 ? 'Next Challenge →' : '🏁 View Results';
  btnNext.classList.toggle('next-style',   idx < CHALLENGES.length - 1);
  btnNext.classList.toggle('finish-style', idx >= CHALLENGES.length - 1);
}

/* ══════════════════════════════════════════════
   SUBMIT ANSWER
══════════════════════════════════════════════ */
function submitAnswer(given) {
  if (answered) return;
  answered = true;

  const c         = CHALLENGES[currentIdx];
  const isCorrect = given === c.status;

  if (isCorrect) score += 20;

  // Record
  userAnswers.push({ id: c.id, short: c.short, given, correct: c.status, isCorrect });

  // Button visual feedback
  const btnSafe     = document.getElementById('btn-safe');
  const btnPoisoned = document.getElementById('btn-poisoned');
  btnSafe.disabled     = true;
  btnPoisoned.disabled = true;

  const clickedBtn = given === 'SAFE' ? btnSafe : btnPoisoned;
  clickedBtn.classList.add(isCorrect ? 'correct' : 'wrong');

  // Always reveal the correct button
  const correctBtn = c.status === 'SAFE' ? btnSafe : btnPoisoned;
  if (!isCorrect) correctBtn.classList.add('correct');

  // Feedback panel
  const fb    = document.getElementById('feedback-panel');
  const icon  = document.getElementById('feedback-icon');
  const title = document.getElementById('feedback-title');
  const expl  = document.getElementById('feedback-explain');

  if (isCorrect) {
    fb.className    = 'feedback-panel correct-fb show';
    icon.textContent  = '✅';
    title.textContent = 'Correct! +20 Points';
    expl.innerHTML    = `<span class="tag ${c.status === 'SAFE' ? 'tag-safe' : 'tag-poisoned'}">${c.status}</span> ${c.clue}`;
  } else {
    fb.className    = 'feedback-panel wrong-fb show';
    icon.textContent  = '❌';
    title.textContent = 'Not Quite!';
    expl.innerHTML    = `The correct answer was <span class="tag ${c.status === 'SAFE' ? 'tag-safe' : 'tag-poisoned'}">${c.status}</span>. ${c.clue}`;
  }

  // Show next button
  document.getElementById('btn-next').classList.add('show');

  // Update score display
  document.getElementById('score-text').textContent = `Score: ${score}`;

  // Toast
  showToast(isCorrect ? '✅ Correct! +20 pts' : '❌ Wrong — study the clue!');
}

/* ══════════════════════════════════════════════
   NEXT CHALLENGE
══════════════════════════════════════════════ */
function nextChallenge() {
  currentIdx++;
  if (currentIdx >= CHALLENGES.length) {
    showResults();
  } else {
    loadChallenge(currentIdx);
    window.scrollTo(0, 0);
  }
}

/* ══════════════════════════════════════════════
   RESULTS
══════════════════════════════════════════════ */
function showResults() {
  showScreen('screen-results');

  const correct = userAnswers.filter(a => a.isCorrect).length;
  const wrong   = userAnswers.length - correct;

  document.getElementById('final-score').textContent  = score;
  document.getElementById('correct-count').textContent = correct;
  document.getElementById('wrong-count').textContent   = wrong;

  // Score color
  const scoreEl = document.getElementById('final-score');
  if      (score === 100) scoreEl.style.color = '#00e676';
  else if (score >= 80)   scoreEl.style.color = '#4caf50';
  else if (score >= 60)   scoreEl.style.color = '#ffc107';
  else                    scoreEl.style.color = '#e53935';

  // Rank
  let rank, message, badgeColor, badgeSecond;
  if (score === 100) {
    rank        = '⭐ Elite Cyber-Scout';
    message     = 'Perfect score! You identified every threat with precision. You\'re ready to lead digital safety workshops for your troop.';
    badgeColor  = '#00bcd4';
    badgeSecond = '#00e676';
  } else if (score >= 80) {
    rank        = '🏅 Cyber-Scout Badge Earned';
    message     = 'Outstanding fieldwork! You correctly unmasked most threats. Review the ones you missed and you\'ll be unstoppable.';
    badgeColor  = '#4caf50';
    badgeSecond = '#00bcd4';
  } else if (score >= 60) {
    rank        = '📋 Scout-in-Training';
    message     = 'Good effort! You\'re developing your link-analysis skills. Re-read the clues in the review below and try again.';
    badgeColor  = '#ffc107';
    badgeSecond = '#4caf50';
  } else {
    rank        = '🔰 Recruit';
    message     = 'The digital wilderness is tricky — every expert started where you are. Study the after-action review and run the mission again!';
    badgeColor  = '#e53935';
    badgeSecond = '#ffc107';
  }

  document.getElementById('results-rank').textContent  = rank;
  document.getElementById('rank-message').textContent  = message;

  // Badge SVG
  document.getElementById('results-badge-svg').innerHTML = `
    <polygon points="50,4 61,28 88,30 68,50 74,77 50,64 26,77 32,50 12,30 39,28"
             stroke="${badgeColor}" stroke-width="2" fill="rgba(76,175,80,.1)"
             style="filter:drop-shadow(0 0 8px ${badgeColor}66)"/>
    <polygon points="50,14 58,30 76,32 62,46 66,63 50,55 34,63 38,46 24,32 42,30"
             stroke="${badgeSecond}" stroke-width="1" fill="none" opacity=".5"/>
    <text x="50" y="52" text-anchor="middle" dominant-baseline="middle"
          font-family="'Segoe UI',system-ui,sans-serif"
          font-size="${score===100?'22':'18'}" font-weight="900"
          fill="${badgeColor}">${score}</text>
  `;

  // Results title
  document.getElementById('results-title').textContent =
    score >= 80 ? 'Mission Complete!' : score >= 60 ? 'Debrief Time' : 'Back to Training';

  // After-action review
  const reviewList = document.getElementById('review-list');
  reviewList.innerHTML = '';
  userAnswers.forEach(a => {
    const c = CHALLENGES.find(ch => ch.id === a.id);
    const div = document.createElement('div');
    div.className = `review-item ${a.isCorrect ? 'correct-item' : 'wrong-item'}`;
    div.innerHTML = `
      <span class="review-result-icon">${a.isCorrect ? '✅' : '❌'}</span>
      <div class="review-content">
        <div class="review-link">${a.short}</div>
        <div class="review-status-line">
          You answered:
          <span class="answer-given ${a.isCorrect ? 'correct-answer' : 'wrong-answer'}">${a.given}</span>
          &nbsp;·&nbsp; Correct:
          <span class="answer-given correct-answer">${a.correct}</span>
        </div>
      </div>
    `;
    reviewList.appendChild(div);
  });

  // Progress bar to 100%
  document.getElementById('progress-bar').style.width = '100%';
}

/* ══════════════════════════════════════════════
   RESTART
══════════════════════════════════════════════ */
function restartGame() {
  startChallenge();
}

/* ══════════════════════════════════════════════
   TOAST
══════════════════════════════════════════════ */
let toastTimer;
function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  clearTimeout(toastTimer);
  toastTimer = setTimeout(() => t.classList.remove('show'), 2200);
}
</script>
</body>
</html>